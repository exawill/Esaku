# Server
PORT=3000
NODE_ENV=development
APP_URL=https://esaku.xyz

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Hostinger MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=esaku

# Hostinger OAuth
HOSTINGER_CLIENT_ID=
HOSTINGER_CLIENT_SECRET=
HOSTINGER_REDIRECT_URI=https://esaku.xyz/auth/hostinger/callback
HOSTINGER_AUTHORIZE_URL=https://api.hostinger.com/oauth/authorize
HOSTINGER_TOKEN_URL=https://api.hostinger.com/oauth/token
HOSTINGER_USERINFO_URL=https://api.hostinger.com/oauth/userinfo

# Admin defaults
ADMIN_EMAIL=Admin@esaku.xyz
